{
  "name": "hey-comma",
  "version": "1.2.0",
  "description": "Run shell commands using natural language",
  "repository": "git@github.com:TimoBechtel/hey-comma.git",
  "author": "Timo Bechtel",
  "license": "MIT",
  "type": "module",
  "bin": {
    "hey,": "./dist/index.js",
    "hey": "./dist/index.js"
  },
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "gpt",
    "hey comma",
    "ai",
    "shell"
  ],
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "prepare": "is-ci || husky install",
    "prepack": "bun run build",
    "build": "bun build.ts"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^17.8.1",
    "@commitlint/config-conventional": "^17.8.1",
    "@timobechtel/style": "^2.0.1",
    "@types/node": "^25.3.0",
    "bun-types": "^1.3.9",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.0.1",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "commander": "^14.0.3",
    "conf": "^11.0.2",
    "enquirer": "^2.4.1",
    "openai": "^4.104.0",
    "ora": "^9.3.0"
  }
}
