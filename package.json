{
  "name": "hey-comma",
  "version": "1.2.0",
  "description": "Run shell commands using natural language",
  "repository": "git@github.com:TimoBechtel/hey-comma.git",
  "author": "Timo Bechtel",
  "license": "MIT",
  "type": "module",
  "bin": {
    "hey,": "./dist/hey",
    "hey": "./dist/hey"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "gpt",
    "hey comma",
    "ai",
    "shell"
  ],
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "prepare": "is-ci || husky install",
    "prepack": "bun run build",
    "build": "bun build ./src/index.ts --compile --outfile ./dist/hey --minify",
    "build:linux": "bun build ./src/index.ts --compile --target=bun-linux-x64 --outfile ./dist/hey-linux-x64 --minify",
    "build:windows": "bun build ./src/index.ts --compile --target=bun-windows-x64 --outfile ./dist/hey-windows-x64.exe --minify",
    "build:macos": "bun build ./src/index.ts --compile --target=bun-darwin-arm64 --outfile ./dist/hey-darwin-arm64 --minify",
    "build:macos-intel": "bun build ./src/index.ts --compile --target=bun-darwin-x64 --outfile ./dist/hey-darwin-x64 --minify",
    "build:all": "bun run build && bun run build:linux && bun run build:windows && bun run build:macos && bun run build:macos-intel"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^17.8.1",
    "@commitlint/config-conventional": "^17.8.1",
    "@timobechtel/style": "^2.0.1",
    "@types/node": "^25.3.0",
    "bun-types": "^1.3.9",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/google": "^3.0.30",
    "@ai-sdk/openai": "^3.0.30",
    "@iarna/toml": "^2.2.5",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "ai": "^6.0.97",
    "commander": "^14.0.3",
    "conf": "^11.0.2",
    "enquirer": "^2.4.1",
    "ora": "^9.3.0"
  }
}
